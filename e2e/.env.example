# E2E test environment variables
# Copy this file to .env.test (git-ignored) and fill in real values.
# The playwright.config.js loads .env.test automatically.
#
# NEVER commit .env.test — it contains secrets.

# Supabase project URL (from Project Settings > API)
SUPABASE_URL=https://your-project.supabase.co

# Supabase service-role key — bypasses RLS, for test cleanup only
# Found in: Project Settings > API > service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Base URL for E2E tests (default: https://freedoliapp.vercel.app)
# E2E_BASE_URL=http://localhost:5173
