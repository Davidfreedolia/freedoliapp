# Production environment — comitted to repo so Vercel picks it up at build time.
# .env.local is NOT deployed; this file IS.

# ── Beta billing bypass ──────────────────────────────────────────────────────
# During closed beta there are no Stripe subscriptions, so all billing gates
# must be bypassed on the frontend. Remove both flags once Stripe is live.
VITE_DISABLE_SEAT_LIMIT=true
VITE_BETA_MODE=true
